# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments (recreate via `python -m venv` + requirements.txt) ─
venv/
.venv/
env/
backend/venv/
backend/.venv/

# ── Node / Next.js ─────────────────────────────────────────────────────────
node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo
next-env.d.ts

# ── Local databases (the demo seeder regenerates these on first run) ───────
backend/data/*.db
backend/data/chroma_db/
backend/data/sebi_circulars/*.txt
*.sqlite
*.sqlite3
*.db-journal

# ── Secrets ─ NEVER commit these ───────────────────────────────────────────
backend/.env
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
*.pkl

# ── Fine-tune outputs (push adapter to HuggingFace Hub instead) ────────────
finetune/adapters/
finetune/data/sebi_train.jsonl
finetune/data/sebi_test.jsonl
finetune/data/dataset_hash.txt
finetune/wandb/

# ── Editor / OS ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Build artifacts that shouldn't be in source control ────────────────────
*.log
logs/
coverage/
.coverage
htmlcov/

# ── Video / media (kept out of repo, hosted on YouTube + media gallery) ────
assets/raw/
assets/exports/
*.mp4
*.mov
*.wav
*.mp3
# Allow the cover image and architecture diagram (HTML, not heavy assets)
!docs/cover-image.html
!docs/architecture.html
