# Copy these into Railway service variables for the backend service.
# Do not commit a real .env file with secrets.

DEMO_MODE=true
FRONTEND_URL=https://your-vercel-app.vercel.app
FRONTEND_ORIGINS=https://your-vercel-app.vercel.app
FRONTEND_ORIGIN_REGEX=https://.*\.vercel\.app

# Real Gemma inference requires this to point at a reachable Ollama/GPU runtime.
# Leave unset only if you want the UI to show the explicit Gemma-unavailable state.
OLLAMA_HOST=https://your-ollama-gpu-runtime.example.com
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT_S=120

PAPER_CAPITAL=100000
PYTHONUNBUFFERED=1

# Optional Live Kite Connect credentials. Keep these on Railway only.
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=https://your-railway-service.up.railway.app/kite/callback
